# ──────────────────────────────────────────────────────────────────────────────
# Smart Screen — Production Environment Template
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.production and fill in your real values.
# Then deploy with:
#   docker compose --env-file .env.production -f docker-compose.yml -f docker-compose.prod.yml up --build -d
#
# Generate secrets with: openssl rand -hex 32
# ──────────────────────────────────────────────────────────────────────────────

# ── Domains (REQUIRED) ────────────────────────────────────────────────────────
# These are used by nginx to route traffic to the correct service.
DASHBOARD_DOMAIN=app.yourdomain.com
ADMIN_DOMAIN=admin.yourdomain.com
API_DOMAIN=api.yourdomain.com
PLAYER_DOMAIN=player.yourdomain.com
MARKETING_DOMAIN=yourdomain.com

# ── SSL Certificates (REQUIRED) ───────────────────────────────────────────────
# Path to Let's Encrypt or your SSL certificates on the VPS host.
SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem

# ── CORS / Allowed Origins (REQUIRED) ─────────────────────────────────────────
# Exact comma-separated list of browser origins permitted to call the API.
ALLOWED_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com,https://player.yourdomain.com

# ── Public URLs (REQUIRED) ────────────────────────────────────────────────────
# How browsers reach the API (through nginx).
NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com/api/v1
NEXT_PUBLIC_REALTIME_URL=https://api.yourdomain.com
MEDIA_PUBLIC_BASE_URL=https://api.yourdomain.com/media-files
NEXT_PUBLIC_DASHBOARD_URL=https://app.yourdomain.com

# ── Secrets (REQUIRED — generate with openssl rand -hex 32) ───────────────────
JWT_ACCESS_SECRET=<generate-with-openssl-rand-hex-32>
JWT_REFRESH_SECRET=<generate-a-different-one>
PLAYER_HEARTBEAT_SECRET=<generate-another-one>
ENCRYPTION_KEY=<generate-another-one>

# ── Database ──────────────────────────────────────────────────────────────────
# These are used by docker-compose internally. Change the password!
POSTGRES_USER=smartscreen
POSTGRES_PASSWORD=<strong-db-password>
POSTGRES_DB=smartscreen

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Reverse Proxy ─────────────────────────────────────────────────────────────
# Set to 1 when behind nginx/Cloudflare (required for correct client IP detection).
TRUST_PROXY_HOPS=1

# ── Cookie Security ───────────────────────────────────────────────────────────
# Must be true in production (HTTPS). Cookies will be Secure + SameSite=lax.
COOKIE_SECURE=true

# ── Storage ───────────────────────────────────────────────────────────────────
# "local" = files on disk (volume mount). "s3" = S3-compatible (MinIO, R2, etc.)
MEDIA_STORAGE_PROVIDER=local
# If using S3:
# S3_BUCKET=smartscreen
# S3_REGION=auto
# S3_ENDPOINT=http://minio:9000
# S3_ACCESS_KEY=<access-key>
# S3_SECRET_KEY=<secret-key>

# ── MinIO ─────────────────────────────────────────────────────────────────────
# Change these from defaults!
MINIO_ROOT_USER=<minio-admin-user>
MINIO_ROOT_PASSWORD=<minio-admin-password>

# ── Database Pool ─────────────────────────────────────────────────────────────
DATABASE_POOL_MAX=20
DATABASE_POOL_TIMEOUT_MS=30000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=300

# ── JWT Expiry ────────────────────────────────────────────────────────────────
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Heartbeat ─────────────────────────────────────────────────────────────────
HEARTBEAT_STALE_MS=45000
HEARTBEAT_SWEEP_MS=10000

# ── Pairing ───────────────────────────────────────────────────────────────────
PAIRING_SESSION_TTL_MS=900000

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Smart Screen
# Configure one email provider:
# RESEND_API_KEY=re_...
# SENDGRID_API_KEY=SG....
# SMTP_HOST=smtp.yourdomain.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=true

# ── Stripe (optional) ─────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_PRO=price_...
# STRIPE_PRICE_ID_STARTER=price_...
# STRIPE_PRICE_ID_ENTERPRISE=price_...
# STRIPE_CHECKOUT_SUCCESS_URL=https://app.yourdomain.com/en/billing?checkout=success&session_id={CHECKOUT_SESSION_ID}
# STRIPE_CHECKOUT_CANCEL_URL=https://app.yourdomain.com/en/billing?checkout=canceled

# ── Security: disable in production ───────────────────────────────────────────
NEXT_PUBLIC_ALLOW_MOCK_BILLING=false
# ENABLE_MOCK_BILLING=false
# ENABLE_DB_SEED=false
# ENABLE_DEV_LOGIN=false
ENABLE_SWAGGER=false

# ── Admin IP Allowlist (optional but recommended) ─────────────────────────────
# Comma-separated IPs allowed to access platform admin endpoints.
# ADMIN_ALLOWED_IPS=10.0.0.1,10.0.0.2

# ── Sentry (optional) ─────────────────────────────────────────────────────────
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0

# ── Metrics (optional) ────────────────────────────────────────────────────────
# METRICS_AUTH_TOKEN=<generate-with-openssl-rand-hex-32>

# ── Audit Log Retention ───────────────────────────────────────────────────────
# AUDIT_LOG_RETENTION_DAYS=90
