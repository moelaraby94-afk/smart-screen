DATABASE_URL="postgresql://cloudsignage:cloudsignage_dev_password@localhost:5432/cloudsignage?schema=public"
NEXT_PUBLIC_DEFAULT_LOCALE="en"
NEXT_PUBLIC_SUPPORTED_LOCALES="en,ar"
# In production the backend refuses to boot unless each secret below is >=32 chars,
# uses >=8 distinct characters, is not a known placeholder, and JWT_ACCESS_SECRET
# differs from JWT_REFRESH_SECRET. Generate each with: openssl rand -hex 32
JWT_ACCESS_SECRET="replace-with-strong-access-secret"
JWT_REFRESH_SECRET="replace-with-strong-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
# Backend listen port. main.ts uses `process.env.PORT || 3000`, and the dashboard dev
# server also takes 3000 — leave this unset and `npm run dev` collides on that port.
PORT="4000"
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000/api/v1"
# Dashboard SSR → API inside Docker: http://backend:4000/api/v1 (see docker-compose.yml). Leave empty for local dev.
INTERNAL_API_BASE_URL=""
FRONTEND_ORIGIN="http://localhost:3000"
# Include 127.0.0.1 if you open the dashboard at http://127.0.0.1:3000 (different browser Origin than localhost).
FRONTEND_ORIGINS="http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001"
# REQUIRED when NODE_ENV=production (see apps/backend/src/main.ts) — the backend refuses to
# start in production without this set. Exact comma-separated allow-list of browser origins
# permitted to call the API with credentials; NOT used in local dev (NODE_ENV != production).
# ALLOWED_ORIGINS="https://app.example.com,https://admin.example.com"
# Legacy fallback only: accepted for screens created outside the pairing flow (seeded /
# manually created), which have no per-screen secret. Screens paired via the 6-digit code
# get their own secret at pairing time and ignore this value entirely.
PLAYER_HEARTBEAT_SECRET="dev-player-heartbeat-secret"
# Pairing v2: TTL for 6-digit screen pairing sessions (ms). Default 900000 (15 minutes).
PAIRING_SESSION_TTL_MS="900000"
# Stripe webhook signing secret (Dashboard → Webhooks → Signing secret). Leave unset to reject webhooks.
STRIPE_WEBHOOK_SECRET=""
HEARTBEAT_STALE_MS="45000"
HEARTBEAT_SWEEP_MS="10000"
NEXT_PUBLIC_REALTIME_URL="http://localhost:4000"
# Kiosk (legacy / manually created screens): set serial + secret.
# Pairing v2 needs neither — leave the serial unset and the player shows a 6-digit code;
# after the dashboard claims it, the serial and the screen's own secret are stored in
# localStorage. Note this value is inlined into the player's client bundle, so it is
# public to anyone who loads the player page — never reuse a real secret here.
NEXT_PUBLIC_PLAYER_SCREEN_SERIAL="PLAYER-DEMO-001"
NEXT_PUBLIC_PLAYER_HEARTBEAT_SECRET="dev-player-heartbeat-secret"
# Optional: splash / loading logo URL for apps/player (pairing & bootstrap overlays).
NEXT_PUBLIC_PLAYER_PLACEHOLDER_LOGO=""
# Player playlist image/video: `cover` (default) or `contain`.
NEXT_PUBLIC_PLAYER_MEDIA_OBJECT_FIT=""
# Optional: when set, player pairing POST notifies this workspace over Socket.IO (`pairing:started`) so the dashboard Add Screen modal can react.
NEXT_PUBLIC_PAIRING_WORKSPACE_ID=""

# --- Email (pick one provider) ---
EMAIL_FROM="noreply@example.com"
EMAIL_FROM_NAME="Cloud Signage"
# RESEND_API_KEY="re_..."
# SENDGRID_API_KEY="SG...."
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_SECURE="false"

# --- Stripe Checkout (server) ---
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_PRICE_ID_PRO="price_..."
# STRIPE_PRICE_ID_STARTER="price_..."
# STRIPE_PRICE_ID_ENTERPRISE="price_..."
# STRIPE_CHECKOUT_SUCCESS_URL="https://app.example.com/en/billing?checkout=success&session_id={CHECKOUT_SESSION_ID}"
# STRIPE_CHECKOUT_CANCEL_URL="https://app.example.com/en/billing?checkout=canceled"
# Optional: return URL after Stripe Customer Portal (default: FRONTEND_ORIGIN + /{locale}/settings/billing)
# STRIPE_PORTAL_RETURN_URL="https://app.example.com/en/settings/billing"

# Dashboard: show demo subscription buttons (Free/Pro) in billing UI. Omit or "false" in production.
NEXT_PUBLIC_ALLOW_MOCK_BILLING="true"
# API: allow PATCH /subscriptions/mock-plan and admin subscription-mock in production (dangerous — off by default).
# ENABLE_MOCK_BILLING="true"

# Optional: allow POST /auth/dev-login in production (default off).
# ENABLE_DEV_LOGIN="true"

# Optional: allow `npm run prisma:seed` to run when NODE_ENV=production (default off — dev/local only).
# ENABLE_DB_SEED="true"

# Optional error reporting (Sentry initializes when DSN is set).
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_TRACES_SAMPLE_RATE="0"
