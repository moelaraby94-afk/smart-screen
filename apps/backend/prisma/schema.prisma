generator client {

  provider = "prisma-client-js"

}



datasource db {

  provider = "postgresql"

}



enum UserRole {

  OWNER

  ADMIN

  EDITOR

  VIEWER

}



enum InvitationStatus {

  PENDING

  ACCEPTED

  EXPIRED

  CANCELLED

}



/// Internal Cloud Signage employees (governance). Null = customer / tenant user only.
enum PlatformStaffRole {

  SUPER_ADMIN

  SUPPORT_SPECIALIST

  BILLING_MANAGER

}



enum ScreenStatus {

  ONLINE

  OFFLINE

  MAINTENANCE

}



enum ScreenOrientation {

  AUTO

  LANDSCAPE

  PORTRAIT

}

enum RenderMode {

  CONTAIN

  COVER

  CENTER

  FIT_WIDTH

  FIT_HEIGHT

}



enum CanvasType {

  IMAGE

  VIDEO

  URL

  WIDGET

}



enum SubscriptionPlan {

  FREE

  STARTER

  PRO

  ENTERPRISE

}



enum SubscriptionStatus {

  TRIALING

  ACTIVE

  PAST_DUE

  CANCELED

}



/// Physical or runtime player stack (blueprint: Android / Tizen / webOS / web).

enum PlayerPlatform {

  ANDROID

  TIZEN

  WEBOS

  WEB

}



enum ScreenPairingSessionStatus {

  PENDING

  COMPLETE

  EXPIRED

  CANCELLED

}

/// Per-customer (tenant user) subscription tier for admin CRM — distinct from workspace Subscription.
enum UserSubscriptionStatus {

  ACTIVE

  EXPIRED

  TRIAL

}



/// Lifecycle states for a Campaign: draft → submit → approve/reject → publish → pause/resume → end
enum CampaignStatus {

  DRAFT

  PENDING_APPROVAL

  APPROVED

  REJECTED

  PUBLISHED

  PAUSED

  ENDED

}



enum RecurrenceType {

  WEEKLY

  MONTHLY

  ONCE

  DAILY

}



model User {

  id               String            @id @default(cuid())

  email            String            @unique

  fullName         String

  passwordHash     String

  refreshTokenHash String?

  locale           String            @default("en")

  isActive         Boolean           @default(true)

  /// Platform super-admin: sees all workspaces; role checks bypass.
  isSuperAdmin     Boolean           @default(false)

  /// Internal staff role (Support / Billing). Super Admin may also set SUPER_ADMIN for parity with UI.
  platformStaffRole PlatformStaffRole?

  /// Customer subscription tier (admin CRM). EXPIRED may also be implied when subscriptionEndDate is past.
  subscriptionStatus UserSubscriptionStatus @default(TRIAL)

  /// When the customer-level subscription ends (UTC). Null = not set / open-ended trial.
  subscriptionEndDate DateTime?

  /// Last successful password login (UTC). Updated on login and register.
  lastLoginAt      DateTime?

  businessName     String?

  phone            String?

  /// ISO 3166-1 alpha-2 (e.g. US, AE)
  country          String?

  city             String?

  emailVerified    Boolean           @default(false)

  /// Email / registration OTP (cleared after verify). Short-lived.
  verificationCode String?

  verificationCodeExpiresAt DateTime?

  passwordResetToken String?

  passwordResetExpiresAt DateTime?

  pendingEmail     String?

  pendingEmailOtp  String?

  pendingEmailOtpExpiresAt DateTime?

  /// TOTP secret (base32) for 2FA. Null when 2FA is not enabled.
  twoFactorSecret   String?

  /// Whether 2FA is enabled. Secret is kept for re-enabling convenience.
  twoFactorEnabled  Boolean           @default(false)

  /// Backup codes (bcrypt hashes, JSON array) for account recovery.
  twoFactorBackupCodes String?

  /// Per-user notification preferences (JSON object of type -> boolean)
  notificationPreferences Json?

  createdAt        DateTime          @default(now())

  updatedAt        DateTime          @updatedAt

  memberships      WorkspaceMember[]

  sentInvitations  WorkspaceInvitation[] @relation("SentInvitations")

  createdCanvases  Canvas[]          @relation("CanvasCreatedBy")

  savedCanvasVersions CanvasVersion[] @relation("CanvasVersionSavedBy")

  payments         PaymentRecord[]

  pairingClaimLockout PairingClaimLockout[]

  refreshTokens     RefreshToken[]

  ownedPlaylists      Playlist[]       @relation("OwnedPlaylists")

  ownedMedia          Media[]          @relation("OwnedMedia")

  ownedMediaFolders   MediaFolder[]    @relation("OwnedMediaFolders")

  ownedPlaylistGroups PlaylistGroup[]  @relation("OwnedPlaylistGroups")

  accountOwnership    AccountMember[]  @relation("AccountOwnership")

  accountMemberships  AccountMember[]  @relation("AccountMembership")

  createdCampaigns    Campaign[]       @relation("CampaignCreatedBy")

  approvedCampaigns   Campaign[]       @relation("CampaignApprovedBy")

}



model PaymentRecord {

  id           String   @id @default(cuid())

  userId       String

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  amountCents  Int

  currency     String   @default("USD")

  status       String

  description  String?

  invoiceRef   String?

  paidAt       DateTime?

  /// e.g. stripe, moyasar

  provider     String?

  /// Provider event / intent id for idempotency

  externalId   String?  @unique

  metadata     Json?

  createdAt    DateTime @default(now())

  @@index([userId, createdAt])

}



model Workspace {

  id            String            @id @default(cuid())

  name          String

  slug          String            @unique

  defaultLocale String            @default("en")

  timezone      String            @default("UTC")

  /// When true, player bootstrap rejects playback for this workspace (dashboard still works).
  isPaused      Boolean           @default(false)

  createdAt     DateTime          @default(now())

  updatedAt     DateTime          @updatedAt

  members       WorkspaceMember[]

  screens       Screen[]

  canvases      Canvas[]

  medias        Media[]          @relation("MediaWorkspace")
  mediaFolders  MediaFolder[]    @relation("MediaFolderWorkspace")

  screenPairingSessions ScreenPairingSession[]

  playlists     Playlist[]       @relation("PlaylistWorkspace")

  schedules     Schedule[]

  overrideRules ScreenOverrideRule[]

  subscription  Subscription?

  invitations   WorkspaceInvitation[]

  apiKeys       ApiKey[]

  webhookEndpoints WebhookEndpoint[]

  onboardingProgress OnboardingProgress?

  featureFlags  FeatureFlag[]

  prayerConfig  PrayerConfig?

  ramadanConfig RamadanConfig?

  accountMemberScopes AccountMemberWorkspaceScope[]

  campaigns     Campaign[]

}



model WorkspaceMember {

  id          String    @id @default(cuid())

  workspaceId String

  userId      String

  role        UserRole  @default(VIEWER)

  createdAt   DateTime  @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)



  @@unique([workspaceId, userId])

  @@index([userId])

}



model WorkspaceInvitation {

  id          String           @id @default(cuid())

  workspaceId String

  email       String

  role        UserRole         @default(VIEWER)

  token       String           @unique

  status      InvitationStatus @default(PENDING)

  invitedById String

  createdAt   DateTime         @default(now())

  expiresAt   DateTime

  acceptedAt  DateTime?

  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  invitedBy   User             @relation("SentInvitations", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([workspaceId, email])

  @@index([email])

}



model Screen {

  id               String       @id @default(cuid())

  workspaceId      String

  name             String

  serialNumber     String       @unique

  status           ScreenStatus @default(OFFLINE)

  location         String?

  lastSeenAt       DateTime?

  /// Last player heartbeat reported running from offline cache (API unreachable).
  isOfflineCacheMode Boolean @default(false)

  activePlaylistId String?

  /// Bottom marquee / ticker text pushed to the player HUD

  playerTicker     String?

  /// Player software version reported via heartbeat
  playerVersion    String?

  playerPlatform   PlayerPlatform @default(WEB)

  resolutionWidth  Int            @default(1920)

  resolutionHeight Int            @default(1080)

  /// Device diagnostics reported via heartbeat (0–100, null if not available)
  batteryLevel     Int?

  /// Battery charging status reported via heartbeat
  batteryCharging  Boolean?

  /// Player uptime in seconds reported via heartbeat
  uptimeSeconds    Int?

  /// Network connection type reported via heartbeat (wifi, ethernet, etc.)
  networkType      String?

  /// Player orientation lock: auto follows screen aspect, portrait forces 90° rotation, landscape forces 0°.
  orientation      ScreenOrientation @default(AUTO)

  /// Hash (bcrypt) of a per-screen secret generated at pairing time. Replaces
  /// the shared PLAYER_HEARTBEAT_SECRET for screens paired after this was
  /// introduced. Null for screens paired before it existed — those fall back
  /// to the shared secret (see player.service.ts / realtime.gateway.ts).
  pairingSecretHash String?

  createdAt        DateTime     @default(now())

  updatedAt        DateTime     @updatedAt

  workspace        Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  pairingSession     ScreenPairingSession?

  /// Organizational bucket: screens belong to this playlist for branch UI (not necessarily active playback).
  playlistGroupId  String?

  playlistGroup    Playlist?    @relation("PlaylistGroupForScreen", fields: [playlistGroupId], references: [id], onDelete: SetNull)

  activePlaylist   Playlist?    @relation("ActivePlaylistForScreen", fields: [activePlaylistId], references: [id], onDelete: SetNull)

  /// One-click override: force this playlist until overrideExpiresAt
  overridePlaylistId String?
  overrideExpiresAt  DateTime?
  overridePlaylist   Playlist?    @relation("ScreenOverridePlaylist", fields: [overridePlaylistId], references: [id], onDelete: SetNull)

  schedules Schedule[]

  /// Multiple playlists assigned to this screen with ordering (rotation)
  playlistAssignments ScreenPlaylistAssignment[]

  /// Advanced override rules with date/time/recurrence
  overrideRules ScreenOverrideRule[]

  campaigns     Campaign[]     @relation("CampaignScreen")

  @@index([workspaceId, playlistGroupId])

  @@index([workspaceId, status])

  @@index([workspaceId, lastSeenAt])

}



/// Ephemeral 6-digit code + poll secret for dashboard ↔ player linking (v2). Legacy kiosk flow unchanged.

model ScreenPairingSession {

  id          String   @id @default(cuid())

  code        String   @unique

  pollSecret  String

  status      ScreenPairingSessionStatus @default(PENDING)

  workspaceId String?

  screenId    String?  @unique

  playerPlatform   PlayerPlatform @default(WEB)

  resolutionWidth  Int            @default(1920)

  resolutionHeight Int            @default(1080)

  /// Plaintext per-screen secret staged at claim time, delivered exactly
  /// once via the first COMPLETE pollSession response, then cleared to null.
  screenSecretHandoff String?

  expiresAt   DateTime

  createdAt   DateTime @default(now())

  updatedAt   DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  screen    Screen?    @relation(fields: [screenId], references: [id], onDelete: SetNull)

  @@index([status, expiresAt])

  @@index([workspaceId, status])

}



/// Per-user brute-force lockout for ScreenPairingSession.code claim guesses (POST
/// :workspaceId/pairing-sessions/claim). Keyed by userId (not IP) since the endpoint
/// already requires a JWT. Independent of, and stricter than, the per-minute ThrottlerGuard
/// on the same route.
model PairingClaimLockout {

  id            String   @id @default(cuid())

  userId        String

  /// IP address of the claim attempt. Used alongside userId so that
  /// multiple accounts from the same IP still accumulate failures.
  ip            String   @default("unknown")

  /// Wrong-code claim attempts within the current window (see windowStartAt).
  failedCount   Int      @default(0)

  /// Start of the current 10-minute failure-counting window; failures outside it reset the counter.
  windowStartAt DateTime

  /// Set once failedCount reaches the threshold; claim attempts are rejected while this is in the future.
  lockedUntil   DateTime?

  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ip])

  @@index([ip, lockedUntil])

  @@index([lockedUntil])

}



/// Per-session refresh token storage (replaces the single refreshTokenHash on User).
/// Each login/impersonation creates a new row; logout deletes all rows for the user.
/// The sessionId is embedded in the JWT refresh payload so the token can be looked
/// up directly without scanning every hash.
model RefreshToken {

  id          String   @id @default(cuid())

  userId      String

  /// Random session identifier embedded in the JWT `sid` claim.
  sessionId   String

  tokenHash   String

  /// When the refresh token expires (mirrors JWT exp).
  expiresAt   DateTime

  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sessionId])

  @@index([userId, expiresAt])

}



/// Idempotent payment / webhook processing (Stripe event id, etc.)

model ProcessedWebhookEvent {

  id          String   @id @default(cuid())

  provider    String

  externalId  String

  createdAt   DateTime @default(now())

  @@unique([provider, externalId])

}



/// Creative Studio design: vector layout + optional legacy URL fields

model Canvas {

  id            String         @id @default(cuid())

  workspaceId   String

  createdById   String

  name          String

  type          CanvasType     @default(WIDGET)

  durationSec   Int            @default(15)

  /// Legacy / external URL (optional)

  contentUrl    String?

  /// Konva-exported scene graph (objects, version)

  layoutData    Json           @default("{}")

  width         Int            @default(1920)

  height        Int            @default(1080)

  metadata      Json?

  createdAt     DateTime       @default(now())

  updatedAt     DateTime       @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdBy     User           @relation("CanvasCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  playlistItems PlaylistItem[]

  versions      CanvasVersion[]

}

/// Snapshot of a canvas at a point in time — created on each save.

model CanvasVersion {

  id            String         @id @default(cuid())

  canvasId      String

  /// Snapshot of layoutData at the time of save

  layoutData    Json

  /// Snapshot of name at the time of save

  name          String

  /// Snapshot of dimensions at the time of save

  width         Int

  height        Int

  /// Who saved this version

  savedById     String

  createdAt     DateTime       @default(now())

  canvas        Canvas         @relation(fields: [canvasId], references: [id], onDelete: Cascade)

  savedBy       User           @relation("CanvasVersionSavedBy", fields: [savedById], references: [id], onDelete: Restrict)

  @@index([canvasId, createdAt(sort: Desc)])

}



model Media {

  id            String         @id @default(cuid())

  ownerId       String

  workspaceId   String?

  fileName      String

  originalName  String

  mimeType      String

  sizeBytes     Int

  relativePath  String
  folderId      String?

  /// Detected media width in pixels (images/video frames)
  width         Int?

  /// Detected media height in pixels (images/video frames)
  height        Int?

  /// SHA-256 hash of file content for integrity checking
  fileHash      String?

  createdAt     DateTime       @default(now())

  updatedAt     DateTime       @updatedAt

  /// Optional expiry date. When set, media is auto-deleted after this date.
  expiresAt     DateTime?

  owner         User           @relation("OwnedMedia", fields: [ownerId], references: [id], onDelete: Cascade)

  workspace     Workspace?     @relation("MediaWorkspace", fields: [workspaceId], references: [id], onDelete: SetNull)

  folder        MediaFolder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)

  playlistItems PlaylistItem[]



  @@index([ownerId, createdAt])
  @@index([ownerId, folderId, createdAt])
  @@index([workspaceId, createdAt])

}

model MediaFolder {

  id          String   @id @default(cuid())

  ownerId     String

  workspaceId String?

  name        String

  createdAt   DateTime @default(now())

  updatedAt   DateTime @updatedAt

  owner     User       @relation("OwnedMediaFolders", fields: [ownerId], references: [id], onDelete: Cascade)

  workspace Workspace? @relation("MediaFolderWorkspace", fields: [workspaceId], references: [id], onDelete: SetNull)

  medias    Media[]

  @@unique([ownerId, name])

  @@index([ownerId, createdAt])

}


model Playlist {

  id              String         @id @default(cuid())

  ownerId         String

  workspaceId     String?

  groupId         String?

  name            String

  isPublished     Boolean        @default(false)

  /// Display orientation this playlist is designed for
  orientation     ScreenOrientation @default(AUTO)

  /// How media should be rendered on screen (contain = no crop, cover = fill, etc.)
  renderMode      RenderMode     @default(CONTAIN)

  /// Target rendering width in pixels (e.g. 1920 for landscape, 1080 for portrait)
  targetWidth     Int?

  /// Target rendering height in pixels (e.g. 1080 for landscape, 1920 for portrait)
  targetHeight    Int?

  createdAt       DateTime       @default(now())

  updatedAt       DateTime       @updatedAt

  owner           User           @relation("OwnedPlaylists", fields: [ownerId], references: [id], onDelete: Cascade)

  workspace       Workspace?     @relation("PlaylistWorkspace", fields: [workspaceId], references: [id], onDelete: SetNull)

  group           PlaylistGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  items           PlaylistItem[]

  assignedScreens Screen[]       @relation("ActivePlaylistForScreen")

  overrideScreens Screen[]       @relation("ScreenOverridePlaylist")

  screensInGroup  Screen[]       @relation("PlaylistGroupForScreen")

  screenAssignments ScreenPlaylistAssignment[]

  overrideRuleScreens ScreenOverrideRule[]

  schedules       Schedule[]

  campaigns       Campaign[]      @relation("CampaignPlaylist")

  /// Items in other playlists that reference this playlist as a nested item
  nestedPlaylistItems PlaylistItem[] @relation("NestedPlaylistItems")

  @@index([ownerId, updatedAt])

  @@index([workspaceId])

  @@index([workspaceId, isPublished])

}



model PlaylistItem {

  id          String   @id @default(cuid())

  playlistId  String

  /// Exactly one of mediaId, canvasId, or playlistId must be set (enforced in app)

  mediaId     String?

  canvasId    String?

  /// Nested playlist reference — allows a playlist to contain another playlist as an item

  nestedPlaylistId String?

  orderIndex  Int

  durationSec Int      @default(10)

  /// Zone name for multi-zone layouts (null = single/full-screen)
  zoneName   String?

  createdAt   DateTime @default(now())

  playlist    Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  media       Media?   @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  canvas      Canvas?  @relation(fields: [canvasId], references: [id], onDelete: Restrict)

  /// The nested playlist referenced by this item (null for media/canvas items)
  nestedPlaylist Playlist? @relation("NestedPlaylistItems", fields: [nestedPlaylistId], references: [id], onDelete: SetNull)



  @@unique([playlistId, orderIndex])

  @@index([mediaId])

  @@index([canvasId])

  @@index([nestedPlaylistId])

}



/// When content should play: days 0-6 (Sun-Sat), HH:mm times in workspace TZ
model Schedule {

  id          String   @id @default(cuid())

  workspaceId String

  /// null = all screens in workspace; set = single screen
  screenId    String?

  playlistId  String

  daysOfWeek  Int[]

  /// WEEKLY (matches daysOfWeek) or MONTHLY (matches daysOfMonth)
  recurrence  RecurrenceType @default(WEEKLY)

  /// Days of month (1..31) used when recurrence = "MONTHLY"
  daysOfMonth Int[]    @default([])

  startTime   String

  endTime     String

  startDate   DateTime?

  endDate     DateTime?

  priority    Int      @default(0)

  enabled     Boolean  @default(true)

  /// If true, schedule is skipped on holidays defined for this workspace
  excludeHolidays Boolean @default(false)

  createdAt   DateTime @default(now())

  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  screen    Screen?   @relation(fields: [screenId], references: [id], onDelete: Cascade)

  playlist  Playlist  @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([workspaceId])

  @@index([screenId])

  @@index([playlistId])

  @@index([screenId, startTime, endTime])

  @@index([workspaceId, startDate])

}



/// Multiple playlists assigned to a screen with ordering for rotation playback
model ScreenPlaylistAssignment {

  id          String   @id @default(cuid())

  screenId    String

  playlistId  String

  /// Order in the rotation (0 = first to play)
  orderIndex  Int      @default(0)

  createdAt   DateTime @default(now())

  updatedAt   DateTime @updatedAt

  screen    Screen   @relation(fields: [screenId], references: [id], onDelete: Cascade)

  playlist  Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@unique([screenId, playlistId])

  @@index([screenId, orderIndex])

}



/// Advanced override rule: force a playlist on a screen with date/time/recurrence and conflict detection
model ScreenOverrideRule {

  id          String   @id @default(cuid())

  workspaceId String

  screenId    String

  playlistId  String

  /// ONCE = one-time date range, DAILY = every day in time window, WEEKLY = specific days of week, MONTHLY = specific days of month
  recurrence  RecurrenceType @default(ONCE)

  /// For WEEKLY: days 0-6 (Sun-Sat). Empty = all days
  daysOfWeek  Int[]    @default([])

  /// For MONTHLY: days 1-31. Empty = all days
  daysOfMonth Int[]    @default([])

  /// Start date for ONCE mode (inclusive)
  startDate   DateTime?

  /// End date for ONCE mode (inclusive)
  endDate     DateTime?

  /// Daily start time HH:mm
  startTime   String   @default("00:00")

  /// Daily end time HH:mm
  endTime     String   @default("23:59")

  enabled     Boolean  @default(true)

  createdAt   DateTime @default(now())

  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  screen    Screen   @relation(fields: [screenId], references: [id], onDelete: Cascade)

  playlist  Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@index([workspaceId, screenId])

  @@index([screenId, enabled])

  @@index([playlistId])

}



model Subscription {

  id               String             @id @default(cuid())

  workspaceId      String             @unique

  plan             SubscriptionPlan   @default(FREE)

  status           SubscriptionStatus @default(TRIALING)

  seats            Int                @default(1)

  screenLimit      Int                @default(1)

  /// Null = no workspace storage quota (legacy). When set, media uploads should sum to this cap.
  /// BigInt (Postgres BIGINT): multi-GB quotas overflow a 32-bit Int (max ~2.1GB).

  storageLimitBytes BigInt?

  startedAt        DateTime           @default(now())

  currentPeriodEnd DateTime?

  canceledAt       DateTime?

  /// Set when a payment fails — workspace retains paid features until this date.
  gracePeriodEndsAt DateTime?

  /// Set after Stripe Checkout / subscription webhooks (Billing Portal).
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique

  createdAt        DateTime           @default(now())

  updatedAt        DateTime           @updatedAt

  workspace        Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([status, currentPeriodEnd])

}


/// Cross-tenant audit trail (impersonation, privileged logins).
/// Lives in Postgres rather than a JSON file: the previous file-backed store did
/// read-modify-write with no locking, so concurrent appends silently dropped
/// entries — the one record type that must never be lost.
model AuditLog {

  id             String   @id @default(cuid())

  /// Machine-readable event name, e.g. "IMPERSONATE_USER".
  action         String

  /// Display name of the acting staff member at the time of the event.
  adminName      String

  /// Display name of the affected customer at the time of the event.
  targetCustomer String

  /// Real client IP as seen by the API, or "n/a" when the caller had no request context.
  ipAddress      String

  /// Optional workspace ID for workspace-level audit events.
  workspaceId    String?

  /// Optional user ID of the actor for workspace-level events.
  userId         String?

  /// Optional JSON metadata for additional context.
  metadata       Json?

  createdAt      DateTime @default(now())

  @@index([createdAt])

  @@index([workspaceId, createdAt])

}

/// Per-account brute-force lockout for sign-in. Rate limiting is per IP, so a
/// distributed attempt against one account — or one from an office NAT — is
/// otherwise unbounded. Keyed on the submitted email (not a userId) so a
/// non-existent address is locked out identically to a real one, which stops
/// the lockout from being used to enumerate accounts.
model LoginLockout {

  id            String   @id @default(cuid())

  /// Lowercased email as submitted at sign-in.
  email         String   @unique

  /// Failed sign-in attempts within the current window (see windowStartAt).
  failedCount   Int      @default(0)

  /// Start of the current failure-counting window; failures outside it reset the counter.
  windowStartAt DateTime

  /// Set once failedCount hits the threshold; sign-in is refused while this is in the future.
  lockedUntil   DateTime?

  updatedAt     DateTime @updatedAt

  @@index([lockedUntil])

}

model Notification {

  id           String   @id @default(cuid())

  userId       String

  type         String

  title        String

  message      String

  read         Boolean  @default(false)

  /// Optional link to navigate to when clicked (e.g. /screens, /schedules)

  link         String?

  createdAt    DateTime @default(now())

  @@index([userId, read, createdAt])

  @@index([userId, createdAt])

  @@index([userId, type, createdAt(sort: Desc)])

}

model ApiKey {

  id          String    @id @default(cuid())

  workspaceId String

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  name        String

  /// SHA-256 hash of the raw key. The raw key is only shown once at creation time.

  keyHash     String    @unique

  /// Prefix of the key (cs_live_…) for display identification without revealing the full key.

  keyPrefix   String

  /// Space-delimited scopes: "screens:read playlists:read write" etc. Empty = all scopes.

  scopes      String    @default("")

  /// Soft-revoked: key is no longer accepted but row is retained for audit.

  revokedAt   DateTime?

  lastUsedAt  DateTime?

  createdAt   DateTime  @default(now())

  @@index([workspaceId, revokedAt])

}

model WebhookEndpoint {

  id          String    @id @default(cuid())

  workspaceId String

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  url         String

  /// Space-delimited event types: "screen.online screen.offline media.uploaded" etc.

  events      String

  /// HMAC-SHA256 signing secret used to sign payloads sent to the endpoint.

  secret      String

  /// Soft-deleted: endpoint is no longer active but row is retained for audit.

  deletedAt   DateTime?

  enabled     Boolean   @default(true)

  createdAt   DateTime  @default(now())

  updatedAt   DateTime  @updatedAt

  deliveryLogs WebhookDeliveryLog[]

  @@index([workspaceId, enabled])

}

model WebhookDeliveryLog {

  id            String   @id @default(cuid())

  webhookId     String

  webhook       WebhookEndpoint @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  attempt       Int

  statusCode    Int?

  responseBody  String?

  status        String   @default("PENDING")

  createdAt     DateTime @default(now())

  @@index([webhookId, createdAt])

}

model OnboardingProgress {

  id              String   @id @default(cuid())

  workspaceId     String   @unique

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  /// JSON array of completed step keys: ["create_screen","upload_media","create_playlist","schedule_content","invite_team"]

  completedSteps  Json     @default("[]")

  /// When true the onboarding widget is hidden from the dashboard.

  dismissed       Boolean  @default(false)

  /// When the onboarding was marked as fully complete (all steps done).

  completedAt     DateTime?

  createdAt       DateTime @default(now())

  updatedAt       DateTime @updatedAt

}

model FeatureFlag {

  id              String   @id @default(cuid())

  workspaceId     String

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  /// Module key: "billing","api_keys","webhooks","analytics","campaigns","ai","emergency","proof_of_play","templates"

  module          String

  /// Whether the module is enabled for this workspace.

  enabled         Boolean  @default(true)

  /// Who set this flag: "super_admin" or "system".

  setBy           String   @default("system")

  createdAt       DateTime @default(now())

  updatedAt       DateTime @updatedAt

  @@unique([workspaceId, module])

  @@index([workspaceId, enabled])

}

model PrayerConfig {

  id              String   @id @default(cuid())

  workspaceId     String   @unique

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  /// Calculation method: "MWL","Egypt","Makkah","Karachi","ISNA","Tehran","Jafari"

  method          Int      @default(3)

  /// Asr juristic method: 0 = Shafii (standard), 1 = Hanafi

  asrJuristic     Int      @default(0)

  /// Latitude for prayer calculations

  latitude        Float?

  /// Longitude for prayer calculations

  longitude       Float?

  /// City name for display

  city            String?

  /// Minutes to pause content before each prayer

  bufferBefore    Int      @default(5)

  /// Minutes to pause content after each prayer

  bufferAfter     Int      @default(15)

  /// Which prayers to auto-pause for (JSON array: ["Fajr","Dhuhr","Asr","Maghrib","Isha"])

  enabledPrayers  Json     @default("[\"Fajr\",\"Dhuhr\",\"Asr\",\"Maghrib\",\"Isha\"]")

  /// Whether prayer-based auto-pause is active

  autoPauseEnabled Boolean @default(false)

  createdAt       DateTime @default(now())

  updatedAt       DateTime @updatedAt

}

model RamadanConfig {

  id              String   @id @default(cuid())

  workspaceId     String   @unique

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  /// Whether Ramadan mode is currently active

  enabled         Boolean  @default(false)

  /// Playlist to show during Iftar time

  iftarPlaylistId String?

  /// Playlist to show during Suhoor time

  suhoorPlaylistId String?

  /// Minutes before Iftar to switch content

  iftarBuffer     Int      @default(10)

  /// Minutes before Suhoor to switch content

  suhoorBuffer    Int      @default(10)

  /// Show Hijri date on player screens

  showHijriDate   Boolean  @default(true)

  /// Show prayer times on player screens

  showPrayerTimes Boolean  @default(true)

  /// Ramadan start date (auto-activate)

  startDate       DateTime?

  /// Ramadan end date (auto-deactivate)

  endDate         DateTime?

  createdAt       DateTime @default(now())

  updatedAt       DateTime @updatedAt

}



/// Playlist grouping for account-level playlist organization

model PlaylistGroup {

  id            String          @id @default(cuid())

  ownerId       String

  name          String

  parentGroupId String?

  createdAt     DateTime        @default(now())

  updatedAt     DateTime        @updatedAt

  owner         User            @relation("OwnedPlaylistGroups", fields: [ownerId], references: [id], onDelete: Cascade)

  parent        PlaylistGroup?  @relation("PlaylistGroupHierarchy", fields: [parentGroupId], references: [id], onDelete: Cascade)

  children      PlaylistGroup[] @relation("PlaylistGroupHierarchy")

  playlists     Playlist[]

  @@unique([ownerId, name])

  @@index([parentGroupId])

}



/// Account-level membership (sees all workspaces + all playlists/media owned by the account).
/// If workspaceScopes is empty → account-wide access with `role`.
/// If workspaceScopes has entries → access only to those workspaces with per-scope roles.

model AccountMember {

  id          String   @id @default(cuid())

  ownerId     String

  userId      String

  role        UserRole @default(VIEWER)

  createdAt   DateTime @default(now())

  owner       User     @relation("AccountOwnership", fields: [ownerId], references: [id], onDelete: Cascade)

  user        User     @relation("AccountMembership", fields: [userId], references: [id], onDelete: Cascade)

  workspaceScopes AccountMemberWorkspaceScope[]

  @@unique([ownerId, userId])

}



/// Optional per-workspace role override for an account member.
/// When present, the member can only access the listed workspaces.
/// The role on each scope can differ from the account-level role.

model AccountMemberWorkspaceScope {

  id              String   @id @default(cuid())

  accountMemberId String

  workspaceId     String

  role            UserRole @default(VIEWER)

  createdAt       DateTime @default(now())

  accountMember   AccountMember @relation(fields: [accountMemberId], references: [id], onDelete: Cascade)

  workspace       Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([accountMemberId, workspaceId])

  @@index([workspaceId])

}



/// Promotional campaign with approval workflow: draft → submit → approve/reject → publish → pause/resume → end
model Campaign {

  id          String          @id @default(cuid())

  workspaceId String

  /// User who created the campaign
  createdById String

  /// User who approved the campaign (null until approved)
  approvedById String?

  name        String

  description String?

  /// Optional playlist to play when campaign is published
  playlistId  String?

  /// Optional single screen target (null = all screens)
  screenId    String?

  status      CampaignStatus  @default(DRAFT)

  /// Optional comment on approval/rejection
  reviewComment String?

  startDate   DateTime?

  endDate     DateTime?

  createdAt   DateTime        @default(now())

  updatedAt   DateTime        @updatedAt

  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdBy   User            @relation("CampaignCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  approvedBy  User?           @relation("CampaignApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  playlist    Playlist?       @relation("CampaignPlaylist", fields: [playlistId], references: [id], onDelete: SetNull)

  screen      Screen?         @relation("CampaignScreen", fields: [screenId], references: [id], onDelete: SetNull)

  history     CampaignHistory[]

  @@index([workspaceId])

  @@index([status])

}



/// Immutable audit trail of every campaign state change
model CampaignHistory {

  id          String          @id @default(cuid())

  campaignId  String

  /// User who performed the action
  actorId     String

  /// The action performed (SUBMIT, APPROVE, REJECT, PUBLISH, PAUSE, RESUME, END, CREATE, UPDATE, DELETE)
  action      String

  /// Status before the transition
  fromStatus  CampaignStatus

  /// Status after the transition
  toStatus    CampaignStatus

  /// Optional comment (e.g., rejection reason)
  comment     String?

  createdAt   DateTime        @default(now())

  campaign    Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])

}

/// Platform-wide settings stored as key-value pairs with categories.
/// Replaces the file-based admin-runtime.store.ts.
model PlatformSettings {

  id        String   @id @default(cuid())

  key       String   @unique

  value     String

  category  String

  updatedAt DateTime @updatedAt

  updatedBy String?

  @@index([category])

}

/// One-time, short-lived token for cross-domain impersonation.
/// Platform admin generates a token, customer app redeems it.
model ExchangeToken {

  id           String    @id @default(cuid())

  token        String    @unique

  tokenHash    String    @unique

  actorUserId  String

  targetUserId String

  workspaceId  String?

  expiresAt    DateTime

  usedAt       DateTime?

  createdAt    DateTime  @default(now())

  @@index([tokenHash])

  @@index([expiresAt])

}

/// Security event log for tracking suspicious activities and security-critical actions.
model SecurityEventLog {

  id          String   @id @default(cuid())

  /// Event type: FAILED_LOGIN, BRUTE_FORCE_LOCKOUT, PRIVILEGE_ESCALATION,
  /// SUSPICIOUS_ACTIVITY, RATE_LIMIT_EXCEEDED, CSRF_FAILURE, JWT_INVALID,
  /// IMPERSONATION_START, IMPERSONATION_EXIT, PASSWORD_RESET_REQUESTED
  eventType   String

  /// Severity: LOW, MEDIUM, HIGH, CRITICAL
  severity    String   @default("MEDIUM")

  /// User ID if authenticated, null for anonymous
  userId      String?

  /// Workspace ID if applicable
  workspaceId String?

  /// Client IP address
  ipAddress   String?

  /// User agent string
  userAgent   String?

  /// Additional context as JSON
  metadata    Json?

  createdAt   DateTime @default(now())

  @@index([eventType, createdAt])

  @@index([userId, createdAt])

  @@index([severity, createdAt])

}

/// Proof-of-play tracking: records when content was displayed on a screen.
model ProofOfPlay {

  id          String   @id @default(cuid())

  workspaceId String

  screenId    String

  /// Type of content: MEDIA, CANVAS, PLAYLIST
  contentType String

  /// ID of the content item
  contentId   String?

  /// Name of the content for reporting (denormalized)
  contentName String?

  /// Playlist ID if the item was part of a playlist
  playlistId  String?

  /// When playback started (UTC)
  playedAt    DateTime @default(now())

  /// Duration in seconds the content was displayed
  durationSec Int      @default(0)

  createdAt   DateTime @default(now())

  @@index([workspaceId, playedAt])

  @@index([screenId, playedAt])

  @@index([contentId, playedAt])

}

/// Holiday definitions for schedule exclusion/inclusion.
model Holiday {

  id          String   @id @default(cuid())

  workspaceId String

  /// Holiday name (e.g. "National Day", "Eid al-Fitr")
  name        String

  /// Holiday date (date only, time portion ignored)
  date        DateTime

  /// Optional end date for multi-day holidays (inclusive)
  endDate     DateTime?

  /// If true, schedules with excludeHolidays=true will skip this day
  isRecurring Boolean  @default(false)

  createdAt   DateTime @default(now())

  updatedAt   DateTime @updatedAt

  @@index([workspaceId, date])

}

/// Command acknowledgment from player screens.
model CommandAck {

  id          String   @id @default(cuid())

  screenId    String

  /// Command type that was acknowledged
  command     String

  /// Unique message ID from the emitted command
  messageId   String

  /// ACK status: RECEIVED, EXECUTED, FAILED
  status      String   @default("RECEIVED")

  /// Optional error message if status is FAILED
  errorMessage String?

  createdAt   DateTime @default(now())

  @@index([screenId, createdAt])

  @@index([messageId])

}

/// Crash report from a player device.
model CrashReport {

  id          String   @id @default(cuid())

  screenId    String?

  workspaceId String?

  /// Player software version
  playerVersion String?

  /// Player platform
  platform    String?

  /// Crash stack trace or error message
  stackTrace  String

  /// Additional diagnostic data as JSON
  diagnostics Json?

  /// Client IP
  ipAddress   String?

  createdAt   DateTime @default(now())

  @@index([screenId, createdAt])

  @@index([workspaceId, createdAt])

}

/// OTA (Over-The-Air) update for player software.
model PlayerOtaUpdate {

  id            String   @id @default(cuid())

  /// Version string of the update
  version       String   @unique

  /// Platform: ANDROID, TIZEN, WEBOS, WEB, or ALL
  platform      String   @default("ALL")

  /// Download URL for the update package
  downloadUrl   String

  /// SHA-256 checksum of the update package
  checksum      String?

  /// Release notes
  releaseNotes  String?

  /// Minimum player version required to apply this update
  minVersion    String?

  /// Whether this update is mandatory (forces install)
  isMandatory   Boolean  @default(false)

  /// Whether the update is published and available to players
  isPublished   Boolean  @default(false)

  /// Rollout percentage (0-100) for staged rollouts
  rolloutPercent Int     @default(100)

  createdAt     DateTime @default(now())

  updatedAt     DateTime @updatedAt

  @@index([platform, isPublished])

}
